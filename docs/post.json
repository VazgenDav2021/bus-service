          }
        },
        {
          "name": "Create Driver (Owner Scoped)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{ownerAccessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Driver\",\n  \"email\": \"new.driver@bustransport.com\",\n  \"phone\": \"+1234567893\",\n  \"password\": \"Admin123!\",\n  \"busId\": \"{{busId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/bus-owner/drivers",
              "host": ["{{baseUrl}}"],
              "path": ["{{apiPrefix}}", "bus-owner", "drivers"]
